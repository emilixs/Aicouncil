// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum DriverType {
  OPENAI
  ANTHROPIC
  // GROK uses xAI's API which is OpenAI-compatible
  GROK
}

enum SessionType {
  DISCUSSION
  COMPARISON
}

model Expert {
  id           String     @id @default(cuid())
  name         String
  specialty    String
  systemPrompt String     @db.Text
  driverType   DriverType
  config       Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions  SessionExpert[]
  messages  Message[]
  pollVotes PollVote[]

  @@index([driverType])
}

model Session {
  id               String        @id @default(cuid())
  problemStatement String        @db.Text
  status           SessionStatus @default(PENDING)
  type             SessionType   @default(DISCUSSION)
  maxMessages      Int           @default(20)
  consensusReached   Boolean       @default(false)
  consensusThreshold Float         @default(0.8)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  experts     SessionExpert[]
  messages    Message[]
  metrics     SessionMetrics?
  outcome     DiscussionOutcome?
  evaluations ConsensusEvaluation[]
  polls       Poll[]

  @@index([status])
  @@index([type])
}

model Message {
  id               String      @id @default(cuid())
  sessionId        String
  expertId         String?
  content          String      @db.Text
  role             MessageRole
  isIntervention   Boolean     @default(false)
  timestamp        DateTime    @default(now())
  roundNumber      Int?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  model            String?
  responseTimeMs   Int?
  finishReason     String?
  durationMs       Int?
  tokenCount       Int?
  modelUsed        String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  expert  Expert? @relation(fields: [expertId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([expertId])
  @@index([timestamp])
}

model SessionExpert {
  id        String   @id @default(cuid())
  sessionId String
  expertId  String
  joinedAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  expert  Expert  @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([sessionId, expertId])
  @@index([sessionId])
  @@index([expertId])
}

model SessionMetrics {
  id                    String  @id @default(cuid())
  sessionId             String  @unique
  totalTokens           Int     @default(0)
  totalPromptTokens     Int     @default(0)
  totalCompletionTokens Int     @default(0)
  totalRounds           Int     @default(0)
  totalMessages         Int     @default(0)
  totalInterventions    Int     @default(0)
  durationMs            Int     @default(0)
  avgResponseTimeMs     Float   @default(0)
  estimatedCostUsd      Float   @default(0)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DiscussionOutcome {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  executiveSummary String   @db.Text
  decisions       Json
  actionItems     Json
  keyArguments    Json
  openQuestions   Json
  finalEvaluation Json?
  generatedAt     DateTime @default(now())
  generatedBy     String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ConsensusEvaluation {
  id                  String   @id @default(cuid())
  sessionId           String
  roundNumber         Int
  convergenceScore    Float
  consensusReached    Boolean
  areasOfAgreement    Json
  areasOfDisagreement Json
  progressAssessment  String
  reasoning           String   @db.Text
  evaluatedAt         DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([roundNumber])
}

model Poll {
  id        String     @id @default(cuid())
  sessionId String
  proposal  String     @db.Text
  createdBy String
  status    String     @default("open")
  createdAt DateTime   @default(now())
  closedAt  DateTime?

  votes   PollVote[]
  session Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  expertId  String
  vote      String
  reasoning String   @db.Text
  createdAt DateTime @default(now())

  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  expert Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([pollId, expertId])
  @@index([pollId])
}

